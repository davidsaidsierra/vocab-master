# VocabMaster — variables de entorno (plantilla)
# Copia este archivo a .env y rellena los valores. NUNCA commitees el .env real.

# ── Base de datos ────────────────────────────────────────────────────────────
# Postgres/Neon en la nube. Si se deja VACÍA, usa SQLite local (data/vocab.db).
DATABASE_URL=

# ── Autenticación (obligatorio en producción) ────────────────────────────────
# Secreto para firmar los JWT. Genéralo con: openssl rand -hex 32
JWT_SECRET=
# Admin inicial (se crea al arrancar si no existe). Solo bootstrap.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Modo local abierto (SOLO desarrollo) ─────────────────────────────────────
# "1" permite usar la app en localhost SIN login cuando no hay JWT_SECRET.
# NUNCA definir esto en producción (Render): dejaría la API abierta como admin.
# ALLOW_OPEN_MODE=1

# ── Servicios de IA (free tier) ──────────────────────────────────────────────
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# ── Cuotas de IA (opcionales, con default) ───────────────────────────────────
# PREMIUM_AI_DAILY=40
# AI_COOLDOWN_SECONDS=15

# ── CORS de la extensión de Chrome (opcional) ────────────────────────────────
# Origen de la extensión instalada, si necesitas permitirla por CORS.
# EXTENSION_ORIGIN=chrome-extension://tuiddeextension
